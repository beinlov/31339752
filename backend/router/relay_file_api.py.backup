# -*- coding: utf-8 -*-
"""
脰脨录脤陆脷碌茫脦脛录镁API脛拢驴茅 - 禄霉脫脷脦脛录镁脧碌脥鲁碌脛脙眉脕卯脧脗路垄潞脥脳麓脤卢露脕脠隆

鹿陇脳梅脭颅脌铆:
1. 脝陆脤篓脥篓鹿媒SSH/SMB/HTTP陆芦脙眉脕卯脦脛录镁脨麓脠毛脰脨录脤脦禄脰脙碌脛 commands/ 脛驴脗录
2. 脝陆脤篓露篓脢卤露脕脠隆脰脨录脤脦禄脰脙 status/ 脛驴脗录碌脛脳麓脤卢脦脛录镁
"""
from fastapi import APIRouter, HTTPException
from pydantic import BaseModel
from typing import Optional, List
import json
import logging
import os
from datetime import datetime
from pathlib import Path
import paramiko
from config import RELAY_CONFIG

router = APIRouter()
logger = logging.getLogger(__name__)

class TcpSynAttackRequest(BaseModel):
    """TCP SYN潞茅脣庐鹿楼禄梅脟毛脟贸"""
    target_ip: str
    target_port: int
    capture_interface: Optional[str] = None
    inject_interface: Optional[str] = None

class RelayFileManager:
    """脰脨录脤脦脛录镁鹿脺脌铆脝梅 - 脥篓鹿媒SSH/SFTP虏脵脳梅脭露鲁脤脦脛录镁"""
    
    def __init__(self, host: str, port: int, username: str, password: str, share_path: str):
        self.host = host
        self.port = port
        self.username = username
        self.password = password
        self.share_path = share_path
        
    def _get_sftp_client(self):
        """禄帽脠隆SFTP驴脥禄搂露脣"""
        ssh = paramiko.SSHClient()
        ssh.set_missing_host_key_policy(paramiko.AutoAddPolicy())
        ssh.connect(self.host, port=self.port, username=self.username, password=self.password)
        return ssh.open_sftp(), ssh
        
    def write_command(self, attack_id: str, command_data: dict) -> bool:
        """脨麓脠毛脙眉脕卯脦脛录镁碌陆脰脨录脤脦禄脰脙"""
        try:
            sftp, ssh = self._get_sftp_client()
            
            # 脙眉脕卯脦脛录镁脗路戮露
            remote_file = f"{self.share_path}/commands/{attack_id}_{int(datetime.now().timestamp())}.json"
            
            # 脨麓脠毛脙眉脕卯
            with sftp.open(remote_file, 'w') as f:
                f.write(json.dumps(command_data, indent=2, ensure_ascii=False))
                
            logger.info(f"脙眉脕卯脦脛录镁脪脩脨麓脠毛: {remote_file}")
            
            sftp.close()
            ssh.close()
            return True
            
        except Exception as e:
            logger.error(f"脨麓脠毛脙眉脕卯脦脛录镁脢搂掳脺: {e}")
            return False
            
    def read_status(self, attack_id: str) -> Optional[dict]:
        """露脕脠隆鹿楼禄梅脳麓脤卢脦脛录镁"""
        try:
            sftp, ssh = self._get_sftp_client()
            
            # 脳麓脤卢脦脛录镁脗路戮露
            status_file = f"{self.share_path}/status/{attack_id}_status.json"
            attack_file = f"{self.share_path}/status/{attack_id}_attack.json"
            
            result = {}
            
            # 露脕脠隆脕卢陆脫脳麓脤卢
            try:
                with sftp.open(status_file, 'r') as f:
                    result['connections'] = json.load(f)
            except FileNotFoundError:
                result['connections'] = None
                
            # 露脕脠隆鹿楼禄梅脳麓脤卢
            try:
                with sftp.open(attack_file, 'r') as f:
                    result['attack'] = json.load(f)
            except FileNotFoundError:
                result['attack'] = None
                
            sftp.close()
            ssh.close()
            
            return result if result.get('connections') or result.get('attack') else None
            
        except Exception as e:
            logger.error(f"露脕脠隆脳麓脤卢脦脛录镁脢搂掳脺: {e}")
            return None
            
    def list_all_status(self) -> List[dict]:
        """脕脨鲁枚脣霉脫脨脳麓脤卢脦脛录镁"""
        try:
            sftp, ssh = self._get_sftp_client()
            
            status_dir = f"{self.share_path}/status"
            files = sftp.listdir(status_dir)
            
            all_status = []
            for filename in files:
                if filename.endswith('_status.json'):
                    try:
                        with sftp.open(f"{status_dir}/{filename}", 'r') as f:
                            all_status.append(json.load(f))
                    except Exception as e:
                        logger.error(f"露脕脠隆脦脛录镁 {filename} 脢搂掳脺: {e}")
                        
            sftp.close()
            ssh.close()
            
            return all_status
            
        except Exception as e:
            logger.error(f"脕脨鲁枚脳麓脤卢脦脛录镁脢搂掳脺: {e}")
            return []

# 脠芦戮脰脦脛录镁鹿脺脌铆脝梅脢碌脌媒
relay_manager = None

def init_relay_manager():
    """鲁玫脢录禄炉脰脨录脤脦脛录镁鹿脺脌铆脝梅"""
    global relay_manager
    try:
        relay_manager = RelayFileManager(
            host=RELAY_CONFIG['host'],
            port=RELAY_CONFIG.get('port', 22),
            username=RELAY_CONFIG['username'],
            password=RELAY_CONFIG['password'],
            share_path=RELAY_CONFIG['share_path']
        )
        logger.info("脰脨录脤脦脛录镁鹿脺脌铆脝梅鲁玫脢录禄炉鲁脡鹿娄")
    except KeyError as e:
        logger.error(f"脜盲脰脙脠卤脡脵卤脴脪陋脳脰露脦: {e}")
    except Exception as e:
        logger.error(f"鲁玫脢录禄炉脰脨录脤脦脛录镁鹿脺脌铆脝梅脢搂掳脺: {e}")

@router.post("/relay-file/attack/start")
async def start_attack_via_file(request: TcpSynAttackRequest):
    """脥篓鹿媒脦脛录镁脧脗路垄脝么露炉鹿楼禄梅脙眉脕卯"""
    if not relay_manager:
        raise HTTPException(status_code=500, detail="脰脨录脤脦脛录镁鹿脺脌铆脝梅脦麓鲁玫脢录禄炉")
        
    try:
        attack_id = f"tcp-syn-{int(datetime.now().timestamp())}"
        
        command_data = {
            'type': 'start_attack',
            'attack_id': attack_id,
            'target_ip': request.target_ip,
            'target_port': request.target_port,
            'capture_interface': request.capture_interface,
            'inject_interface': request.inject_interface,
            'timestamp': datetime.now().isoformat()
        }
        
        success = relay_manager.write_command(attack_id, command_data)
        
        if success:
            return {
                'status': 'success',
                'message': '鹿楼禄梅脙眉脕卯脪脩脧脗路垄',
                'attack_id': attack_id
            }
        else:
            raise HTTPException(status_code=500, detail="脨麓脠毛脙眉脕卯脦脛录镁脢搂掳脺")
            
    except Exception as e:
        logger.error(f"脧脗路垄鹿楼禄梅脙眉脕卯脢搂掳脺: {e}")
        raise HTTPException(status_code=500, detail=str(e))

@router.post("/relay-file/attack/stop")
async def stop_attack_via_file(attack_id: str):
    """脥篓鹿媒脦脛录镁脧脗路垄脥拢脰鹿鹿楼禄梅脙眉脕卯"""
    if not relay_manager:
        raise HTTPException(status_code=500, detail="脰脨录脤脦脛录镁鹿脺脌铆脝梅脦麓鲁玫脢录禄炉")
        
    try:
        command_data = {
            'type': 'stop_attack',
            'attack_id': attack_id,
            'timestamp': datetime.now().isoformat()
        }
        
        success = relay_manager.write_command(attack_id, command_data)
        
        if success:
            return {
                'status': 'success',
                'message': '脥拢脰鹿脙眉脕卯脪脩脧脗路垄',
                'attack_id': attack_id
            }
        else:
            raise HTTPException(status_code=500, detail="脨麓脠毛脙眉脕卯脦脛录镁脢搂掳脺")
            
    except Exception as e:
        logger.error(f"脧脗路垄脥拢脰鹿脙眉脕卯脢搂掳脺: {e}")
        raise HTTPException(status_code=500, detail=str(e))

@router.get("/relay-file/attack/{attack_id}/status")
async def get_attack_status_from_file(attack_id: str):
    """麓脫脦脛录镁露脕脠隆鹿楼禄梅脳麓脤卢"""
    if not relay_manager:
        raise HTTPException(status_code=500, detail="脰脨录脤脦脛录镁鹿脺脌铆脝梅脦麓鲁玫脢录禄炉")
        
    try:
        status = relay_manager.read_status(attack_id)
        
        if status:
            return {
                'status': 'success',
                'data': status
            }
        else:
            return {
                'status': 'not_found',
                'message': '脳麓脤卢脦脛录镁虏禄麓忙脭脷禄貌脡脨脦麓脡煤鲁脡'
            }
            
    except Exception as e:
        logger.error(f"露脕脠隆脳麓脤卢脦脛录镁脢搂掳脺: {e}")
        raise HTTPException(status_code=500, detail=str(e))

@router.get("/relay-file/status/all")
async def get_all_status_from_file():
    """露脕脠隆脣霉脫脨鹿楼禄梅脳麓脤卢"""
    if not relay_manager:
        raise HTTPException(status_code=500, detail="脰脨录脤脦脛录镁鹿脺脌铆脝梅脦麓鲁玫脢录禄炉")
        
    try:
        all_status = relay_manager.list_all_status()
        
        return {
            'status': 'success',
            'data': all_status,
            'count': len(all_status)
        }
            
    except Exception as e:
        logger.error(f"露脕脠隆脣霉脫脨脳麓脤卢脢搂掳脺: {e}")
        raise HTTPException(status_code=500, detail=str(e))

@router.get("/relay-file/health")
async def check_relay_connection():
    """录矛虏茅脰脨录脤脕卢陆脫陆隆驴碌脳麓脤卢"""
    if not relay_manager:
        return {
            'status': 'error',
            'message': '脰脨录脤脦脛录镁鹿脺脌铆脝梅脦麓鲁玫脢录禄炉'
        }
        
    try:
        # 鲁垄脢脭脕卢陆脫虏垄脕脨鲁枚脛驴脗录
        sftp, ssh = relay_manager._get_sftp_client()
        files = sftp.listdir(relay_manager.share_path)
        sftp.close()
        ssh.close()
        
        return {
            'status': 'healthy',
            'message': '脰脨录脤脕卢陆脫脮媒鲁拢',
            'share_path': relay_manager.share_path,
            'files_count': len(files)
        }
    except Exception as e:
        return {
            'status': 'unhealthy',
            'message': f'脰脨录脤脕卢陆脫脪矛鲁拢: {str(e)}'
        }
