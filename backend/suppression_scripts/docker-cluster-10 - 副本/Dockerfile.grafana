FROM grafana/grafana:10.0.6-ubuntu

# 切换到root用户
USER root

# 设置环境变量
ENV PYTHONUNBUFFERED=1
ENV DEBIAN_FRONTEND=noninteractive

WORKDIR /app

# 安装Python3（Grafana镜像基于Ubuntu，有apt）
RUN apt-get update && \
    apt-get install -y python3 python3-pip && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

# 复制代码
COPY . .

# 暴露UDP端口
EXPOSE 8000/udp

# 启动命令
CMD ["python3", "main.py"]
