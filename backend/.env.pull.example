# ============================================================
# 平台服务器环境变量配置 - 拉取模式 (Pull Mode)
# ============================================================
# 复制此文件为 .env.pull 并根据实际情况修改
# 使用方式: source .env.pull && python3 main.py

# ============================================================
# 数据传输模式配置
# ============================================================

# 数据传输模式（pull 或 push）
# - pull: 平台主动从C2端拉取数据（传统模式，推荐）
# - push: 平台被动接收中转服务器推送数据（需要中转服务器）
export DATA_TRANSFER_MODE="pull"

# ============================================================
# C2端点配置（拉取模式）
# ============================================================
# 注意：实际的C2端点配置在 config.py 的 C2_ENDPOINTS 中
# 这里的环境变量用于覆盖默认配置

# 是否启用远程拉取
export ENABLE_REMOTE_PULLING="true"

# ============================================================
# 数据库配置（可选）
# ============================================================
# 如果需要覆盖默认数据库配置，可以在这里设置
# export DATABASE_URL="postgresql://user:pass@localhost/dbname"

# ============================================================
# 日志配置（可选）
# ============================================================
# export LOG_LEVEL="INFO"

# ============================================================
# API配置（可选）
# ============================================================
# export API_PORT="8000"
# export API_HOST="0.0.0.0"

# ============================================================
# 说明
# ============================================================
# 1. 拉取模式下，平台服务器主动从C2端拉取数据
# 2. 需要确保网络能连接到C2端（可能需要VPN）
# 3. 不需要中转服务器
# 4. C2端点配置在 config.py 中的 C2_ENDPOINTS 数组

# ============================================================
# 启动方式
# ============================================================
# source .env.pull && python3 main.py
