# ========================================
# 平台服务器推送模式环境变量配置示例
# ========================================
# 使用方法：
# 1. 复制此文件为 .env
# 2. 填写实际值
# 3. 使用 source .env 或在启动脚本中加载
# ========================================

# 数据传输模式（必须设置为 push）
export DATA_TRANSFER_MODE="push"

# ========== API认证配置 ==========
# ⚠️ 必须与中转服务器配置一致！
# 对应：relay/relay_config.json -> pusher.platform_api_key
export PUSH_API_KEY="KiypG4zWLXqnREqGPH8L2Oh9ybvi6Yh4"

# ========== HMAC签名密钥 ==========
# ⚠️ 必须与中转服务器配置一致！
# 对应：relay/relay_config.json -> pusher.signature_secret
# [TODO] 生成命令：openssl rand -hex 32
export PUSH_SIGNATURE_SECRET="CHANGE_ME_IN_PRODUCTION_use_strong_random_key_here"

# ========== 可选配置 ==========
# 时间戳容忍度（秒）
# export PUSH_TIMESTAMP_TOLERANCE="300"

# Nonce缓存大小
# export PUSH_NONCE_CACHE_SIZE="10000"

# 单次推送最大数据条数
# export PUSH_MAX_BATCH_SIZE="5000"
