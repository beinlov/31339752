# ========================================
# C2端服务器环境变量配置示例
# ========================================
# 使用方法：
# 1. 复制此文件为 .env
# 2. 填写实际值
# 3. 使用 source .env 或在启动脚本中加载
# ========================================

# ========== API认证配置 ==========
# C2端API密钥
# ⚠️ 必须与中转服务器配置一致！
# 对应：relay/relay_config.json -> puller.c2_servers[].api_key
export C2_API_KEY="KiypG4zWLXqnREqGPH8L2Oh9ybvi6Yh4"

# ========== HTTP服务器配置 ==========
# 监听地址（默认：0.0.0.0）
export C2_HTTP_HOST="0.0.0.0"

# 监听端口（默认：8888）
export C2_HTTP_PORT="8888"

# ========== 可选配置 ==========
# 僵尸网络类型（如果需要覆盖配置文件）
# export BOTNET_TYPE="utg_q_008"

# 缓存数据库路径
# export CACHE_DB_FILE="/tmp/c2_data_cache.db"

# 最大缓存记录数
# export MAX_CACHED_RECORDS="10000"
