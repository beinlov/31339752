# ========================================
# 中转服务器环境变量配置示例
# ========================================
# 使用方法：
# 1. 复制此文件为 .env
# 2. 填写实际值
# 3. 使用 source .env 或在启动脚本中加载
# ========================================

# ========== C2端配置 ==========
# C2服务器URL（通过OpenVPN内网）
# [TODO] 确认C2端OpenVPN内网IP
export C2_URL="http://10.8.0.1:8888"

# C2端API密钥
# ⚠️ 必须与C2端配置一致！
# 对应：pull_mode/config.production.json -> http_server.api_key
export C2_API_KEY="KiypG4zWLXqnREqGPH8L2Oh9ybvi6Yh4"

# ========== 平台端配置 ==========
# 平台服务器URL（公网IP或域名）
# [TODO] 填写实际的平台服务器地址
export PLATFORM_URL="http://YOUR_PLATFORM_IP_OR_DOMAIN:8000"

# 平台端API密钥
# ⚠️ 必须与平台端配置一致！
# 对应：backend/config.py -> PUSH_MODE_CONFIG['api_key']
export PLATFORM_API_KEY="KiypG4zWLXqnREqGPH8L2Oh9ybvi6Yh4"

# HMAC签名密钥
# ⚠️ 必须与平台端配置一致！
# 对应：backend/config.py -> PUSH_MODE_CONFIG['signature_secret']
# [TODO] 生成命令：openssl rand -hex 32
export SIGNATURE_SECRET="CHANGE_ME_IN_PRODUCTION_use_strong_random_key_here"

# 中转服务器ID
export RELAY_ID="relay-001"

# ========== AWS配置 ==========
# AWS访问密钥
# [TODO] 填写AWS访问密钥
export AWS_ACCESS_KEY_ID="your-access-key-id"
export AWS_SECRET_ACCESS_KEY="your-secret-access-key"

# AWS区域
# [TODO] 确认AWS区域
export AWS_REGION="us-east-2"

# AWS实例ID
# [TODO] 填写AWS实例ID
# 获取命令：aws ec2 describe-instances --region us-east-2
export AWS_INSTANCE_ID="i-YOUR_INSTANCE_ID_HERE"

# ========== IP切换配置 ==========
# 是否启用IP切换
export IP_CHANGE_ENABLED="true"

# IP切换间隔（秒）
export IP_CHANGE_INTERVAL="600"

# OpenVPN配置文件路径
export OPENVPN_CONFIG="/etc/openvpn/client.conf"

# ========== 可选配置 ==========
# 拉取间隔（秒）
# export PULL_INTERVAL="10"

# 推送间隔（秒）
# export PUSH_INTERVAL="5"
