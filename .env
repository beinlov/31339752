# ============================================================
# 僵尸网络接管集成平台 - 环境变量配置
# ============================================================

# ==================== 数据库配置 ====================
MYSQL_ROOT_PASSWORD=Matrix123
MYSQL_USER=botnet
MYSQL_PASSWORD=Matrix123
MYSQL_DATABASE=botnet

# 前端API地址配置（可选）
# 留空表示使用当前访问域名（推荐用于同域名部署）
# 或指定完整后端地址（用于跨域部署），如: https://api.yourdomain.com
VITE_API_BASE_URL=

# ==================== 后端API配置 ====================
# 日志上传API密钥（建议使用：openssl rand -hex 32 生成）
API_KEY=KiypG4zWLXqnREqGPH8L2Oh9ybvi6Yh4

# SSO接口配置
SSO_TOKEN_EXPIRE_MINUTES=60
SSO_ENABLE_IP_WHITELIST=false

# 用户同步接口API密钥（建议使用：openssl rand -hex 32 生成）
SYNC_API_KEY=your-sync-api-key-here-change-in-production
SYNC_ENABLE_IP_WHITELIST=true

# ==================== 服务端口配置 ====================
# 前端端口
FRONTEND_PORT=9000

# 后端API端口
BACKEND_PORT=8000

# MySQL端口
MYSQL_PORT=3306

# ==================== 时区配置 ====================
TZ=Asia/Shanghai