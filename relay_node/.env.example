# 中继节点环境变量示例
# 复制此文件为 .env 并修改配置

# ========================================
# C2服务器配置
# ========================================
# C2服务器URL（公网访问）
# C2_URL=http://YOUR_C2_IP:8888

# C2 API密钥（必须与C2端一致）
# C2_API_KEY=KiypG4zWLXqnREqGPH8L2Oh9ybvi6Yh4

# ========================================
# 中继节点服务器配置
# ========================================
# 监听地址
# SERVER_HOST=0.0.0.0

# 监听端口
# SERVER_PORT=8888

# 中继节点API密钥（供平台访问）
# RELAY_API_KEY=your_relay_node_api_key

# 是否启用HTTPS
# USE_HTTPS=false

# ========================================
# 间隔配置
# ========================================
# 拉取间隔（秒）
# PULL_INTERVAL=10

# ========================================
# 注意事项
# ========================================
# 1. 环境变量优先级高于配置文件
# 2. 生产环境建议使用强随机密钥
# 3. 启用HTTPS需要配置SSL证书
